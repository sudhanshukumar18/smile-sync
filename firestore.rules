rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 3. Primitive Definition
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidLead(data) {
      return data.keys().hasAll(['name', 'email', 'phone', 'clinicName', 'createdAt']) && 
             data.keys().size() == 5 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.email is string && data.email.size() > 0 && data.email.size() <= 200 &&
             data.phone is string && data.phone.size() > 0 && data.phone.size() <= 20 &&
             data.clinicName is string && data.clinicName.size() > 0 && data.clinicName.size() <= 200 &&
             data.createdAt == request.time;
    }

    // Leads collection
    match /leads/{leadId} {
      allow read: if false; // Only admins in console can read
      allow create: if isValidId(leadId) && isValidLead(incoming());
      allow update: if false; // Leads cannot be updated
      allow delete: if false; // Leads cannot be deleted
    }
  }
}
